{
    "name": "ruki-blog",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build && node scripts/generate-sitemap.js",
        "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "seo:setup": "node scripts/setup-seo.js",
        "seo:generate": "node scripts/generate-sitemap.js",
        "storyblok:push": "storyblok components push --space $SB_SPACE_ID --path ./storyblok",
        "storyblok:pull": "storyblok components pull --space $SB_SPACE_ID --path ./storyblok",
        "posts:rename": "node scripts/rename-posts-to-slugs.js",
        "networth:seed": "node scripts/seed-holdings.js",
        "networth:seed:client": "node scripts/seed-holdings-client.mjs"
    },
    "dependencies": {
        "@mailchimp/mailchimp_marketing": "^3.0.80",
        "@storyblok/react": "^6.1.2",
        "axios": "^1.10.0",
        "concurrently": "^9.2.0",
        "date-fns": "^2.30.0",
        "disqus-react": "^1.1.6",
        "dotenv": "^17.0.1",
        "firebase": "^11.10.0",
        "firebase-admin": "^13.4.0",
        "firebase-functions": "^6.3.2",
        "lucide-react": "^0.294.0",
        "package": "^1.0.1",
        "react": "^18.2.0",
        "react-datepicker": "^9.1.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.20.1",
        "react-share": "^5.2.2",
        "react-slick": "^0.31.0",
        "recharts": "^3.8.1",
        "resend": "^4.6.0",
        "slick-carousel": "^1.8.1",
        "storyblok-rich-text-react-renderer": "^3.0.1"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.10",
        "@types/react": "^18.2.37",
        "@types/react-dom": "^18.2.15",
        "@vitejs/plugin-react": "^4.1.1",
        "autoprefixer": "^10.4.16",
        "eslint": "^8.53.0",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.4",
        "postcss": "^8.4.31",
        "storyblok": "^4.16.8",
        "tailwindcss": "^3.3.5",
        "vite": "^4.5.0",
        "vite-plugin-sitemap": "^0.8.2"
    }
}
